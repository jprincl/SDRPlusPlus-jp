@@ -243,9 +245,41 @@ set(CODEC2_PUBLIC_HEADERS
 set(SOVERSION "${CODEC2_VERSION_MAJOR}.${CODEC2_VERSION_MINOR}")
 message(STATUS "codec2 version: ${CODEC2_VERSION}")
 add_library(codec2 ${CODEC2_SRCS})
+if(CODEC2_CLANGCL)
+    set_target_properties(codec2 PROPERTIES WINDOWS_EXPORT_ALL_SYMBOLS ON)
+endif()
 if(UNIX)
     target_link_libraries(codec2 PUBLIC m)
 endif(UNIX)
+if(CODEC2_CLANGCL)
+    execute_process(
+        COMMAND "${CMAKE_C_COMPILER}" -print-resource-dir
+        OUTPUT_VARIABLE _clang_resource_dir
+        OUTPUT_STRIP_TRAILING_WHITESPACE
+        ERROR_QUIET)
+    set(_clang_rt_arch_candidates "")
+    if(CMAKE_C_COMPILER_ARCHITECTURE_ID MATCHES "ARM64EC" OR CMAKE_C_COMPILER_TARGET MATCHES "arm64ec" OR CMAKE_GENERATOR_PLATFORM MATCHES "ARM64EC" OR CMAKE_SYSTEM_PROCESSOR MATCHES "ARM64EC")
+        list(APPEND _clang_rt_arch_candidates arm64ec aarch64)
+    elseif(CMAKE_C_COMPILER_ARCHITECTURE_ID MATCHES "ARM64|AARCH64|aarch64" OR CMAKE_C_COMPILER_TARGET MATCHES "arm64|aarch64" OR CMAKE_GENERATOR_PLATFORM MATCHES "ARM64" OR CMAKE_SYSTEM_PROCESSOR MATCHES "ARM64|AARCH64|aarch64")
+        list(APPEND _clang_rt_arch_candidates aarch64 arm64)
+    elseif(CMAKE_C_COMPILER_ARCHITECTURE_ID MATCHES "x64|X64|AMD64|amd64" OR CMAKE_C_COMPILER_TARGET MATCHES "x86_64|amd64" OR CMAKE_SIZEOF_VOID_P EQUAL 8)
+        list(APPEND _clang_rt_arch_candidates x86_64)
+    else()
+        list(APPEND _clang_rt_arch_candidates i386)
+    endif()
+    set(_clang_rt_builtins "")
+    foreach(_clang_rt_arch IN LISTS _clang_rt_arch_candidates)
+        set(_clang_rt_candidate "${_clang_resource_dir}/lib/windows/clang_rt.builtins-${_clang_rt_arch}.lib")
+        if(EXISTS "${_clang_rt_candidate}")
+            set(_clang_rt_builtins "${_clang_rt_candidate}")
+            break()
+        endif()
+    endforeach()
+    if(NOT _clang_rt_builtins)
+        message(FATAL_ERROR "Could not find clang_rt.builtins for codec2 clang-cl build below ${_clang_resource_dir}/lib/windows")
+    endif()
+    target_link_libraries(codec2 PRIVATE "${_clang_rt_builtins}")
+endif()
 if(LPCNET AND lpcnetfreedv_FOUND)
     target_link_libraries(codec2 PRIVATE lpcnetfreedv)
 endif()
