{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default",
            "description": "Sensible defaults; lets CMake pick generator from environment",
            "binaryDir": "${sourceDir}/build-default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "sdrpp_deps_DEP_DOWNLOAD_DIR": {
                    "type": "PATH",
                    "value": "${sourceDir}/.pkg_cache"
                }
            }
        },
        {
            "name": "default-arm64",
            "displayName": "Default (ARM64 host/env)",
            "description": "Like 'default' but yields a distinct build directory so ARM64 deps don't share deps/build-default-* with x64 builds. Generator and target arch come from the environment; run from an ARM64-targeted MSVC developer shell.",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build-default-arm64",
            "cacheVariables": {
                "SDRPP_DEP_PROFILE": "portable"
            }
        },
        {
            "name": "vs2026-x64",
            "displayName": "Visual Studio 2026, x64",
            "inherits": "default",
            "generator": "Visual Studio 18 2026",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build-vs2026-x64",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "SDRPP_DEP_PROFILE": "portable"
            }
        },
        {
            "name": "vs2026-arm64",
            "displayName": "Visual Studio 2026, ARM64",
            "inherits": "default",
            "generator": "Visual Studio 18 2026",
            "architecture": "ARM64",
            "binaryDir": "${sourceDir}/build-vs2026-arm64",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "SDRPP_DEP_PROFILE": "portable"
            }
        },
        {
            "name": "android-base",
            "hidden": true,
            "inherits": "default",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_ROOT}/build/cmake/android.toolchain.cmake",
                "ANDROID_PLATFORM": "android-23",
                "ANDROID_STL": "c++_shared",
                "sdrpp_deps_PACKAGE_EXCLUDES": "^(glfw3|LimeSuite|libbladeRF|libfobos|libperseus-sdr|librfnm|portaudio|pthreads|rtaudio|sdrplay|spdlog|zlib)$"
            }
        },
        {
            "name": "android-arm64-v8a",
            "displayName": "Android arm64-v8a",
            "inherits": "android-base",
            "binaryDir": "${sourceDir}/build-android-arm64-v8a",
            "cacheVariables": {
                "ANDROID_ABI": "arm64-v8a"
            }
        },
        {
            "name": "android-armeabi-v7a",
            "displayName": "Android armeabi-v7a",
            "inherits": "android-base",
            "binaryDir": "${sourceDir}/build-android-armeabi-v7a",
            "cacheVariables": {
                "ANDROID_ABI": "armeabi-v7a"
            }
        },
        {
            "name": "android-x86",
            "displayName": "Android x86",
            "inherits": "android-base",
            "binaryDir": "${sourceDir}/build-android-x86",
            "cacheVariables": {
                "ANDROID_ABI": "x86"
            }
        },
        {
            "name": "android-x86_64",
            "displayName": "Android x86_64",
            "inherits": "android-base",
            "binaryDir": "${sourceDir}/build-android-x86_64",
            "cacheVariables": {
                "ANDROID_ABI": "x86_64"
            }
        },
        {
            "name": "appimage",
            "displayName": "Linux AppImage portable deps",
            "inherits": "default",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build-appimage",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "SDRPP_DEP_PROFILE": "portable",
                "SDRPP_DEP_FORCE_SYSTEM": "glfw3"
            }
        }
    ]
}
